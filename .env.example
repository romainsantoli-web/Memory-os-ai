# Memory OS AI — Environment variables
# Copy to .env and adjust values

# SentenceTransformers model name (or local path)
MEMORY_MODEL=all-MiniLM-L6-v2

# Workspace root (defaults to current directory)
# MEMORY_WORKSPACE=/path/to/workspace

# Cache directory for models and embeddings
# MEMORY_CACHE_DIR=/path/to/cache

# Disable tokenizers parallelism warnings
TOKENIZERS_PARALLELISM=false
